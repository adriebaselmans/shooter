<Window x:Class="MapEditor.App.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:MapEditor.App.ViewModels"
        xmlns:core="clr-namespace:MapEditor.Core.Entities;assembly=MapEditor.Core"
        xmlns:views="clr-namespace:MapEditor.App.Views"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="{Binding WindowTitle}"
        Height="900" Width="1400"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Closing="OnWindowClosing">

    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="N" Command="{Binding DataContext.NewFileCommand, ElementName=RootWindow}"/>
        <KeyBinding Modifiers="Control" Key="O" Command="{Binding DataContext.OpenFileCommand, ElementName=RootWindow}"/>
        <KeyBinding Modifiers="Control" Key="S" Command="{Binding DataContext.SaveFileCommand, ElementName=RootWindow}"/>
        <KeyBinding Modifiers="Control" Key="Z" Command="{Binding DataContext.UndoCommand, ElementName=RootWindow}"/>
        <KeyBinding Modifiers="Control" Key="Y" Command="{Binding DataContext.RedoCommand, ElementName=RootWindow}"/>
        <KeyBinding Modifiers="Control+Shift" Key="Z" Command="{Binding DataContext.RedoCommand, ElementName=RootWindow}"/>
        <KeyBinding Modifiers="Control" Key="C" Command="{Binding DataContext.CopySelectedBrushCommand, ElementName=RootWindow}"/>
        <KeyBinding Modifiers="Control" Key="V" Command="{Binding DataContext.PasteBrushCommand, ElementName=RootWindow}"/>
        <KeyBinding Key="Delete" Command="{Binding DataContext.DeleteSelectedCommand, ElementName=RootWindow}"/>
    </Window.InputBindings>

    <Window.Resources>
        <Style TargetType="Button" x:Key="ToolbarButtonStyle">
            <Setter Property="Foreground" Value="#D8D8D8"/>
            <Setter Property="Background" Value="#3A3A3D"/>
            <Setter Property="BorderBrush" Value="#4A4A4E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="MinWidth" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ToolBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToolBorder" Property="Background" Value="#46464A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ToolBorder" Property="Background" Value="#0E639C"/>
                                <Setter TargetName="ToolBorder" Property="BorderBrush" Value="#3FA9F5"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimitiveToolButtonStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="#D8D8D8"/>
            <Setter Property="Background" Value="#3A3A3D"/>
            <Setter Property="BorderBrush" Value="#4A4A4E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="MinWidth" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToolBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToolBorder" Property="Background" Value="#46464A"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToolBorder" Property="Background" Value="#0E639C"/>
                                <Setter TargetName="ToolBorder" Property="BorderBrush" Value="#3FA9F5"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="OperationToolButtonStyle" TargetType="ToggleButton" BasedOn="{StaticResource PrimitiveToolButtonStyle}">
            <Setter Property="MinWidth" Value="32"/>
        </Style>
        <Style x:Key="SurfaceChipButtonStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="#D8D8D8"/>
            <Setter Property="Background" Value="#3A3A3D"/>
            <Setter Property="BorderBrush" Value="#4A4A4E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ChipBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChipBorder" Property="Background" Value="#4A4A4E"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ChipBorder" Property="Background" Value="#0E639C"/>
                                <Setter TargetName="ChipBorder" Property="BorderBrush" Value="#3FA9F5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Menu -->
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="*"/>     <!-- Content -->
            <RowDefinition Height="22"/>    <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ Menu bar ════════════════════════════════════════════════════════ -->
        <Menu Grid.Row="0" Background="#2D2D30" Foreground="#CCCCCC">
            <MenuItem Header="_File" Foreground="#CCCCCC">
                <MenuItem Header="_New"        Command="{Binding NewFileCommand}"     InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Open…"      Command="{Binding OpenFileCommand}"  InputGestureText="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="_Save"       Command="{Binding SaveFileCommand}"  InputGestureText="Ctrl+S"/>
                <MenuItem Header="Save _As…"   Command="{Binding SaveFileAsCommand}"/>
                <Separator/>
                <MenuItem Header="_Exit"       Click="OnExitClick"/>
            </MenuItem>
            <MenuItem Header="_Edit" Foreground="#CCCCCC">
                <MenuItem Header="_Undo"   Command="{Binding UndoCommand}" InputGestureText="Ctrl+Z"/>
                <MenuItem Header="_Redo"   Command="{Binding RedoCommand}" InputGestureText="Ctrl+Y"/>
                <MenuItem Header="_Copy"   Command="{Binding CopySelectedBrushCommand}" InputGestureText="Ctrl+C"/>
                <MenuItem Header="_Paste"  Command="{Binding PasteBrushCommand}" InputGestureText="Ctrl+V"/>
                <Separator/>
                <MenuItem Header="_Delete" Command="{Binding DeleteSelectedCommand}" InputGestureText="Del"/>
            </MenuItem>
            <MenuItem Header="_View" Foreground="#CCCCCC">
                <MenuItem Header="Reset Camera" Click="OnResetCameraClick"/>
                <MenuItem Header="Restore 4-View" Click="OnRestoreViewportLayoutClick"/>
            </MenuItem>
            <MenuItem Header="_Boolean" Foreground="#CCCCCC">
                <MenuItem Header="_Subtract From Intersections"
                          Command="{Binding SubtractSelectedBoxesCommand}"/>
                <MenuItem Header="_Merge Selected"
                          Command="{Binding MergeSelectedBoxesCommand}"/>
            </MenuItem>
            <MenuItem Header="_Help" Foreground="#CCCCCC">
                <MenuItem Header="Texture Workflow _Shortcuts…" Click="OnTextureWorkflowHelpClick"/>
            </MenuItem>
        </Menu>

        <!-- ═══ Toolbar ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="0,0,0,1" Padding="4,2">
            <ToolBar Background="Transparent" Band="0">
                <!-- File actions -->
                <Button Style="{StaticResource ToolbarButtonStyle}" ToolTip="New"  Command="{Binding NewFileCommand}">
                    <ui:SymbolIcon Symbol="DocumentAdd24"/>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}" ToolTip="Open" Command="{Binding OpenFileCommand}">
                    <ui:SymbolIcon Symbol="FolderOpen24"/>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}" ToolTip="Save" Command="{Binding SaveFileCommand}">
                    <ui:SymbolIcon Symbol="Save24"/>
                </Button>
                <Separator/>
                <!-- Undo/Redo -->
                <Button Style="{StaticResource ToolbarButtonStyle}" ToolTip="Undo (Ctrl+Z)" Command="{Binding UndoCommand}">
                    <ui:SymbolIcon Symbol="ArrowUndo24"/>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}" ToolTip="Redo (Ctrl+Y)" Command="{Binding RedoCommand}">
                    <ui:SymbolIcon Symbol="ArrowRedo24"/>
                </Button>
                <Separator/>
                <Border Background="#202024" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="4" Padding="4,3" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <ToggleButton Style="{StaticResource PrimitiveToolButtonStyle}"
                                      ToolTip="Create Box brush"
                                      IsChecked="{Binding IsBoxBrushToolActive, Mode=OneWay}"
                                      Command="{Binding ToggleCreateBrushPrimitiveCommand}"
                                      CommandParameter="{x:Static core:BrushPrimitive.Box}">
                            <Viewbox Width="18" Height="18">
                                <Grid Width="16" Height="16">
                                    <Rectangle Width="11" Height="11" Stroke="#F2F2F2" StrokeThickness="1.3"/>
                                    <Polyline Points="2,5 8,2 14,5 14,11 8,14 2,11 2,5"
                                              Stroke="#F2F2F2"
                                              StrokeThickness="1.1"
                                              Fill="Transparent"/>
                                    <Line X1="8" Y1="2" X2="8" Y2="14" Stroke="#F2F2F2" StrokeThickness="1.1"/>
                                    <Line X1="2" Y1="5" X2="8" Y2="8" Stroke="#F2F2F2" StrokeThickness="1.1"/>
                                    <Line X1="14" Y1="5" X2="8" Y2="8" Stroke="#F2F2F2" StrokeThickness="1.1"/>
                                </Grid>
                            </Viewbox>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource PrimitiveToolButtonStyle}"
                                      ToolTip="Create Cylinder brush"
                                      IsChecked="{Binding IsCylinderBrushToolActive, Mode=OneWay}"
                                      Command="{Binding ToggleCreateBrushPrimitiveCommand}"
                                      CommandParameter="{x:Static core:BrushPrimitive.Cylinder}">
                            <Viewbox Width="18" Height="18">
                                <Grid Width="16" Height="16">
                                    <Ellipse Width="12" Height="4" Stroke="#F2F2F2" StrokeThickness="1.1" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                                    <Line X1="2" Y1="3" X2="2" Y2="12" Stroke="#F2F2F2" StrokeThickness="1.1"/>
                                    <Line X1="14" Y1="3" X2="14" Y2="12" Stroke="#F2F2F2" StrokeThickness="1.1"/>
                                    <Ellipse Width="12" Height="4" Stroke="#F2F2F2" StrokeThickness="1.1" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                                </Grid>
                            </Viewbox>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource PrimitiveToolButtonStyle}"
                                      ToolTip="Create Cone brush"
                                      IsChecked="{Binding IsConeBrushToolActive, Mode=OneWay}"
                                      Command="{Binding ToggleCreateBrushPrimitiveCommand}"
                                      CommandParameter="{x:Static core:BrushPrimitive.Cone}">
                            <Viewbox Width="18" Height="18">
                                <Grid Width="16" Height="16">
                                    <Polygon Points="8,2 2,13 14,13" Stroke="#F2F2F2" StrokeThickness="1.1" Fill="Transparent"/>
                                    <Ellipse Width="12" Height="3.5" Stroke="#F2F2F2" StrokeThickness="1.1" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                                </Grid>
                            </Viewbox>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource PrimitiveToolButtonStyle}"
                                      ToolTip="Create Wedge brush"
                                      Margin="0"
                                      IsChecked="{Binding IsWedgeBrushToolActive, Mode=OneWay}"
                                      Command="{Binding ToggleCreateBrushPrimitiveCommand}"
                                      CommandParameter="{x:Static core:BrushPrimitive.Wedge}">
                            <Viewbox Width="18" Height="18">
                                <Grid Width="16" Height="16">
                                    <Polygon Points="2,13 2,5 14,5 9,13" Stroke="#F2F2F2" StrokeThickness="1.1" Fill="Transparent"/>
                                    <Line X1="2" Y1="5" X2="7" Y2="2" Stroke="#F2F2F2" StrokeThickness="1.1"/>
                                    <Line X1="14" Y1="5" X2="7" Y2="2" Stroke="#F2F2F2" StrokeThickness="1.1"/>
                                </Grid>
                            </Viewbox>
                        </ToggleButton>
                    </StackPanel>
                </Border>
                <Border Background="#202024" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="4" Padding="4,3" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource ToolbarButtonStyle}"
                                Padding="6,4"
                                Margin="0,0,4,0"
                                ToolTip="Subtract the selected brush from all intersecting brushes"
                                Command="{Binding SubtractSelectedBoxesCommand}">
                            <Viewbox Width="18" Height="18">
                                <Grid Width="16" Height="16">
                                    <Rectangle Width="11" Height="11" Stroke="#F2F2F2" StrokeThickness="1.1"/>
                                    <Line X1="3" Y1="8" X2="13" Y2="8" Stroke="#F2F2F2" StrokeThickness="1.3"/>
                                </Grid>
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource ToolbarButtonStyle}"
                                Padding="6,4"
                                Margin="0"
                                ToolTip="Merge the selected brushes into one exact brush"
                                Command="{Binding MergeSelectedBoxesCommand}">
                            <Viewbox Width="18" Height="18">
                                <Grid Width="16" Height="16">
                                    <Rectangle Width="8" Height="8" Stroke="#F2F2F2" StrokeThickness="1.1" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="1,2,0,0"/>
                                    <Rectangle Width="8" Height="8" Stroke="#F2F2F2" StrokeThickness="1.1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,1,2"/>
                                </Grid>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </Border>
                <Separator/>
                <Button Style="{StaticResource ToolbarButtonStyle}" ToolTip="Toggle texture browser (T)" Command="{Binding ToggleTextureBrowserCommand}">
                    <ui:SymbolIcon Symbol="Image24"/>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}" ToolTip="Restore 4-view layout" Click="OnRestoreViewportLayoutClick">
                    <ui:SymbolIcon Symbol="Grid24"/>
                </Button>
            </ToolBar>
        </Border>

        <!-- ═══ Main content ═════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="140"/>  <!-- Outliner -->
                <ColumnDefinition Width="4"/>                   <!-- Splitter -->
                <ColumnDefinition Width="*"/>                   <!-- Viewports -->
                <ColumnDefinition Width="4"/>                   <!-- Splitter -->
                <ColumnDefinition Width="220" MinWidth="160"/>  <!-- Properties -->
            </Grid.ColumnDefinitions>

            <!-- ── Outliner ──────────────────────────────────────────────────── -->
            <Border Grid.Column="0" Background="#252526" BorderBrush="#3F3F46" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="SCENE" Foreground="#969696"
                               FontSize="10" FontWeight="SemiBold"
                               Padding="8,6,8,4"/>
                    <ListView ItemsSource="{Binding Outliner.Items}"
                              SelectedValue="{Binding Outliner.SelectedEntityId}"
                              SelectedValuePath="Id"
                              Background="Transparent"
                              BorderThickness="0"
                              Foreground="#CCCCCC"
                              FontSize="12">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding Kind}" Foreground="#696969" FontSize="10"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="#3F3F46" ResizeBehavior="PreviousAndNext"/>

            <!-- ── 4-viewport area ───────────────────────────────────────────── -->
            <Grid Grid.Column="2" x:Name="ViewportGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <views:ViewportPanel x:Name="ViewportTop"    Grid.Row="0" Grid.Column="0" ViewportLabel="Top (XZ)"/>
                <views:ViewportPanel x:Name="ViewportPersp"  Grid.Row="0" Grid.Column="2" ViewportLabel="Perspective"/>
                <views:ViewportPanel x:Name="ViewportFront"  Grid.Row="2" Grid.Column="0" ViewportLabel="Front (XY)"/>
                <views:ViewportPanel x:Name="ViewportSide"   Grid.Row="2" Grid.Column="2" ViewportLabel="Side (YZ)"/>

                <GridSplitter x:Name="ViewportColumnSplitter" Grid.Row="0" Grid.Column="1" Grid.RowSpan="3"
                              Width="4" HorizontalAlignment="Stretch"
                              Background="#3F3F46" ResizeBehavior="PreviousAndNext"/>
                <GridSplitter x:Name="ViewportRowSplitter" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                              Height="4" VerticalAlignment="Stretch"
                              Background="#3F3F46" ResizeBehavior="PreviousAndNext"/>
            </Grid>

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch"
                          Background="#3F3F46" ResizeBehavior="PreviousAndNext"/>

            <!-- ── Properties panel ──────────────────────────────────────────── -->
            <Border Grid.Row="0" Grid.Column="4" Background="#252526" BorderBrush="#3F3F46" BorderThickness="1,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="PROPERTIES" Foreground="#969696"
                               FontSize="10" FontWeight="SemiBold"
                               Padding="8,6,8,4"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Visibility="{Binding Properties.HasEntity, Converter={StaticResource BoolToVisibility}}"
                                    Margin="8">
                            <TextBlock Text="{Binding Properties.EntityName}" Foreground="#FFFFFF"
                                       FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding Properties.EntityKind}"  Foreground="#969696"
                                       FontSize="10" Margin="0,0,0,12"/>

                            <Expander Header="Brush Details"
                                       IsExpanded="True"
                                       Foreground="#CCCCCC"
                                       Visibility="{Binding CanEditSelectedBrushOperation, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel Margin="0,8,0,0">
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Geometry" Foreground="#CCCCCC" FontSize="11" Margin="0,0,8,4"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Properties.GeometryState}" Foreground="#969696" FontSize="11" Margin="0,0,0,4"/>
                                        <TextBlock Grid.Row="1" Text="Faces" Foreground="#CCCCCC" FontSize="11" Margin="0,0,8,4"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Properties.FaceCountText}" Foreground="#969696" FontSize="11" Margin="0,0,0,4"/>
                                        <TextBlock Grid.Row="2" Text="Materials" Foreground="#CCCCCC" FontSize="11" Margin="0,0,8,0"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Properties.MaterialSummary}" Foreground="#969696" FontSize="11" TextWrapping="Wrap"/>
                                    </Grid>
                                    <TextBlock Text="Boolean actions live in the toolbar and Boolean menu. Select one cutter that intersects others to subtract, or select two or more brushes to merge."
                                               Foreground="#969696"
                                               FontSize="10"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Expander>

                            <Expander Header="Transform" IsExpanded="True" Foreground="#CCCCCC">
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Text="Position" Foreground="#CCCCCC" FontSize="11" Margin="0,0,0,2"/>
                                    <TextBox x:Name="PositionTextBox"
                                             Text="{Binding Properties.PositionText, UpdateSourceTrigger=PropertyChanged}" Background="#2D2D30"
                                             Foreground="#CCCCCC" BorderBrush="#3F3F46" Margin="0,0,0,8"
                                             IsEnabled="{Binding Properties.CanEditTransform}"
                                             KeyDown="OnPropertyEditorKeyDown"
                                             LostFocus="OnPropertyEditorLostFocus"/>

                                    <TextBlock Text="Rotation" Foreground="#CCCCCC" FontSize="11" Margin="0,0,0,2"/>
                                    <TextBox x:Name="RotationTextBox"
                                             Text="{Binding Properties.RotationText, UpdateSourceTrigger=PropertyChanged}" Background="#2D2D30"
                                             Foreground="#CCCCCC" BorderBrush="#3F3F46" Margin="0,0,0,8"
                                             IsEnabled="{Binding Properties.CanEditTransform}"
                                             KeyDown="OnPropertyEditorKeyDown"
                                             LostFocus="OnPropertyEditorLostFocus"/>

                                    <TextBlock Text="Scale" Foreground="#CCCCCC" FontSize="11" Margin="0,0,0,2"/>
                                    <TextBox x:Name="ScaleTextBox"
                                             Text="{Binding Properties.ScaleText, UpdateSourceTrigger=PropertyChanged}" Background="#2D2D30"
                                             Foreground="#CCCCCC" BorderBrush="#3F3F46"
                                             IsEnabled="{Binding Properties.CanEditTransform}"
                                             KeyDown="OnPropertyEditorKeyDown"
                                             LostFocus="OnPropertyEditorLostFocus"/>
                                </StackPanel>
                            </Expander>

                            <Expander Header="Texturing"
                                      IsExpanded="True"
                                      Foreground="#CCCCCC"
                                      Margin="0,12,0,0"
                                      Visibility="{Binding Properties.CanEditTexturing, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel Margin="0,8,0,0">
                                    <Border Background="#1F1F22" BorderBrush="#3F3F46" BorderThickness="1" Padding="8" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="42"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="36" Height="36" BorderBrush="#4A4A4E" BorderThickness="1" Margin="0,0,8,0">
                                                <Image Source="{Binding SelectedTextureEntry.PreviewPath}" Stretch="Fill"/>
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding SelectedTextureEntry.DisplayName, TargetNullValue=No texture selected}"
                                                           Foreground="#F0F0F0" FontSize="11" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding SelectedTextureEntry.Key, TargetNullValue=Choose a texture below}"
                                                           Foreground="#969696" FontSize="10"/>
                                                <TextBlock Text="{Binding SelectedTextureEntry.AverageColorHex}" Foreground="#7FA3D4" FontSize="10"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <WrapPanel Margin="0,0,0,10">
                                        <Button Content="Apply to Brush"
                                                Command="{Binding ApplySelectedTextureToBrushCommand}"
                                                Margin="0,0,6,6"/>
                                        <Button Content="Apply to Faces"
                                                Command="{Binding ApplySelectedTextureToSelectedSurfacesCommand}"
                                                Margin="0,0,0,6"/>
                                    </WrapPanel>

                                    <TextBlock Text="Brush Texture" Foreground="#CCCCCC" FontSize="11" Margin="0,0,0,2"/>
                                    <TextBox Text="{Binding Properties.BrushTextureKey}" Background="#2D2D30"
                                             Foreground="#CCCCCC" BorderBrush="#3F3F46" Margin="0,0,0,8"
                                             IsReadOnly="True"/>

                                    <TextBlock Text="Selected Faces" Foreground="#CCCCCC" FontSize="11" Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding Properties.SelectedSurfaceSummary}" Foreground="#969696" FontSize="10" Margin="0,0,0,6"/>
                                    <ItemsControl ItemsSource="{Binding Properties.SurfaceChips}" Margin="0,0,0,10">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <ToggleButton Content="{Binding DisplayName}"
                                                              Tag="{Binding SurfaceId}"
                                                              Style="{StaticResource SurfaceChipButtonStyle}"
                                                              IsChecked="{Binding IsSelected, Mode=OneWay}"
                                                              Click="OnSurfaceChipClick"
                                                              Margin="0,0,6,6"
                                                              MinWidth="54"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="Offset" Foreground="#CCCCCC" FontSize="11" Margin="0,0,0,2"/>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Text="{Binding Properties.SurfaceOffsetUText, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="#2D2D30"
                                                 Foreground="#CCCCCC"
                                                 BorderBrush="#3F3F46"
                                                 IsEnabled="{Binding Properties.CanEditSurfaceMapping}"
                                                 KeyDown="OnSurfaceMappingEditorKeyDown"
                                                 LostFocus="OnSurfaceMappingEditorLostFocus"/>
                                        <TextBox Grid.Column="2"
                                                 Text="{Binding Properties.SurfaceOffsetVText, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="#2D2D30"
                                                 Foreground="#CCCCCC"
                                                 BorderBrush="#3F3F46"
                                                 IsEnabled="{Binding Properties.CanEditSurfaceMapping}"
                                                 KeyDown="OnSurfaceMappingEditorKeyDown"
                                                 LostFocus="OnSurfaceMappingEditorLostFocus"/>
                                    </Grid>

                                    <TextBlock Text="Scale" Foreground="#CCCCCC" FontSize="11" Margin="0,0,0,2"/>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Text="{Binding Properties.SurfaceScaleUText, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="#2D2D30"
                                                 Foreground="#CCCCCC"
                                                 BorderBrush="#3F3F46"
                                                 IsEnabled="{Binding Properties.CanEditSurfaceMapping}"
                                                 KeyDown="OnSurfaceMappingEditorKeyDown"
                                                 LostFocus="OnSurfaceMappingEditorLostFocus"/>
                                        <TextBox Grid.Column="2"
                                                 Text="{Binding Properties.SurfaceScaleVText, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="#2D2D30"
                                                 Foreground="#CCCCCC"
                                                 BorderBrush="#3F3F46"
                                                 IsEnabled="{Binding Properties.CanEditSurfaceMapping}"
                                                 KeyDown="OnSurfaceMappingEditorKeyDown"
                                                 LostFocus="OnSurfaceMappingEditorLostFocus"/>
                                    </Grid>

                                    <TextBlock Text="Rotation" Foreground="#CCCCCC" FontSize="11" Margin="0,0,0,2"/>
                                    <TextBox x:Name="SurfaceRotationTextBox"
                                             Text="{Binding Properties.SurfaceRotationText, UpdateSourceTrigger=PropertyChanged}"
                                             Background="#2D2D30"
                                             Foreground="#CCCCCC"
                                             BorderBrush="#3F3F46"
                                             Margin="0,0,0,8"
                                             IsEnabled="{Binding Properties.CanEditSurfaceMapping}"
                                             KeyDown="OnSurfaceMappingEditorKeyDown"
                                             LostFocus="OnSurfaceMappingEditorLostFocus"/>

                                    <CheckBox Content="Texture lock"
                                              IsChecked="{Binding Properties.TextureLockEnabled}"
                                              Foreground="#CCCCCC"
                                              Margin="0,0,0,8"
                                              IsEnabled="{Binding Properties.CanEditSurfaceMapping}"
                                              Checked="OnTextureLockChanged"
                                              Unchecked="OnTextureLockChanged"/>

                                    <WrapPanel>
                                        <Button Content="Fit"
                                                Command="{Binding FitSelectedSurfaceMappingsCommand}"
                                                Margin="0,0,6,6"/>
                                        <Button Content="Reset"
                                                Command="{Binding ResetSelectedSurfaceMappingsCommand}"
                                                Margin="0,0,0,6"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="5"
                    Background="#1F1F22"
                    BorderBrush="#3F3F46"
                    BorderThickness="0,1,0,0">
                <Expander IsExpanded="{Binding IsTextureBrowserVisible, Mode=TwoWay}">
                    <Expander.Header>
                        <DockPanel LastChildFill="False">
                            <TextBlock Text="TEXTURES" Foreground="#CCCCCC" FontSize="10" FontWeight="SemiBold" Margin="0,0,12,0"/>
                            <TextBlock Text="T toggles this panel" Foreground="#969696" FontSize="10"/>
                        </DockPanel>
                    </Expander.Header>
                    <DockPanel Margin="8">
                        <TextBox DockPanel.Dock="Top"
                                 Text="{Binding TextureSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#2D2D30"
                                 Foreground="#CCCCCC"
                                 BorderBrush="#3F3F46"
                                 Margin="0,0,0,8"/>
                        <ListBox ItemsSource="{Binding FilteredTextures}"
                                 SelectedValue="{Binding SelectedTextureKey, Mode=TwoWay}"
                                 SelectedValuePath="Key"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#CCCCCC"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel IsItemsHost="True"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="112" Margin="0,0,8,8" Padding="6" Background="#252526" BorderBrush="#3F3F46" BorderThickness="1">
                                        <StackPanel>
                                            <Border Height="72" BorderBrush="#4A4A4E" BorderThickness="1" Margin="0,0,0,6">
                                                <Image Source="{Binding PreviewPath}" Stretch="Fill"/>
                                            </Border>
                                            <TextBlock Text="{Binding DisplayName}" Foreground="#F0F0F0" FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Key}" Foreground="#969696" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding AverageColorHex}" Foreground="#7FA3D4" FontSize="10"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Expander>
            </Border>
        </Grid>

        <!-- ═══ Status bar ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="#007ACC" Padding="8,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusBar.Message}"
                           Foreground="White" FontSize="11"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding StatusBar.BrushCount, StringFormat='Brushes: {0}'}"
                           Foreground="White" FontSize="11"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBlock Grid.Column="2"
                           Text="{Binding StatusBar.ActiveTool, StringFormat='Tool: {0}'}"
                           Foreground="White" FontSize="11"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBlock Grid.Column="3"
                           Text="{Binding StatusBar.LogFileName, StringFormat='Log: {0}'}"
                           ToolTip="{Binding StatusBar.LogFilePath}"
                           Foreground="White" FontSize="11"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
